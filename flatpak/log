Subject: [PATCH] Enable RUST_LOG environment variable
---
Index: Quotient/crypto-sdk/Cargo.toml
IDEA additional info:
Subsystem: com.intellij.openapi.diff.impl.patch.CharsetEP
<+>UTF-8
===================================================================
diff --git a/Quotient/crypto-sdk/Cargo.toml b/Quotient/crypto-sdk/Cargo.toml
--- a/Quotient/crypto-sdk/Cargo.toml	(revision 76a821193a7ffd6495bf2a57908187bb6853ec59)
+++ b/Quotient/crypto-sdk/Cargo.toml	(revision d14da56f195fbbdf70b5d0cffeddef3fca945136)
@@ -19,7 +19,7 @@
 serde = { version = "1", features = ["derive"] }
 serde_json = "1"
 tokio = { version = "1", features = ["full"] }
-tracing-subscriber = "0"
+tracing-subscriber = { version = "0", features = ["env-filter"] }
 log = "0"

 [target.'cfg(target_os = "windows")'.dependencies]
Index: Quotient/crypto-sdk/src/lib.rs
IDEA additional info:
Subsystem: com.intellij.openapi.diff.impl.patch.CharsetEP
<+>UTF-8
===================================================================
diff --git a/Quotient/crypto-sdk/src/lib.rs b/Quotient/crypto-sdk/src/lib.rs
--- a/Quotient/crypto-sdk/src/lib.rs	(revision 76a821193a7ffd6495bf2a57908187bb6853ec59)
+++ b/Quotient/crypto-sdk/src/lib.rs	(revision d14da56f195fbbdf70b5d0cffeddef3fca945136)
@@ -4,6 +4,7 @@
 use matrix_sdk_crypto::OlmMachine;
 use matrix_sdk_sqlite::SqliteCryptoStore;
 use std::{mem::ManuallyDrop, path::Path};
+use tracing_subscriber::{EnvFilter, fmt, prelude::*};

 mod cryptomachine;
 mod encryption_info;
@@ -39,7 +40,10 @@
     account_pickle: String,
 ) -> Box<CryptoMachine> {
     // This will fail when initializing a second account, but that's ok
-    let _ = tracing_subscriber::fmt().try_init();
+    let _ = tracing_subscriber::registry()
+        .with(fmt::layer())
+        .with(EnvFilter::from_default_env())
+        .try_init();
     let rt = tokio::runtime::Runtime::new().expect("Failed to create runtime");
     let _ = rt.enter();

